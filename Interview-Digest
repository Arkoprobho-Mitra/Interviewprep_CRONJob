    .split(/\n(?=\d+[\.\)]\s)/)
    .map(function(p) { return p.trim(); })
    .filter(function(p) { return p.length > 0 && /^\d+[\.\)]/.test(p); });

  // Safety fallback — if split still fails, try splitting on blank lines
  if (problems.length === 0) {
    problems = rawText
      .split(/\n\s*\n/)
      .map(function(p) { return p.trim(); })
      .filter(function(p) { return p.length > 0; });
  }

  if (problems.length === 0) {
    return '<div style="margin-bottom:36px">' +
      '<h2 style="margin:0 0 16px;padding:12px 18px;background:#b45309;color:#fff;' +
      'border-radius:8px;font-size:15px;letter-spacing:.3px">' +
      '💻 DSA Coding Problems</h2>' +
      '<p style="color:#374151;padding:14px 16px">' + rawText + '</p></div>';
  }

  var cards = problems.map(function(prob, idx) {
    var lines     = prob.trim().split("\n");
    var titleLine = lines[0].replace(/^\d+[\.\)]\s*/, "").trim();
    var body      = lines.slice(1).join("\n").trim().replace(/\n/g, "<br>");
    return '<div style="margin-bottom:14px;border:1px solid #fde68a;border-radius:8px;overflow:hidden">' +
      '<div style="background:#fef3c7;padding:10px 16px;border-bottom:1px solid #fde68a">' +
      '<span style="color:#92400e;font-weight:700;font-size:14px">Problem ' + (idx + 1) + '</span>' +
      '<span style="color:#1a1a2e;font-weight:600;font-size:14px"> — ' + titleLine + '</span></div>' +
      '<div style="padding:14px 16px;font-size:13.5px;line-height:1.8;color:#374151">' + body + '</div></div>';
  }).join("");

  return '<div style="margin-bottom:36px">' +
    '<h2 style="margin:0 0 16px;padding:12px 18px;background:#b45309;color:#fff;' +
    'border-radius:8px;font-size:15px;letter-spacing:.3px">' +
    '💻 DSA Coding Problems ' +
    '<span style="font-weight:400;font-size:12px;opacity:.8">(5 problems — write code, then check)</span></h2>' +
    cards + '</div>';
}
  return '<!DOCTYPE html><html><head><meta charset="UTF-8"></head>' +
    '<body style="font-family:-apple-system,BlinkMacSystemFont,\'Segoe UI\',sans-serif;background:#f4f6fb;margin:0;padding:24px">' +
    '<div style="max-width:740px;margin:0 auto;background:#fff;border-radius:12px;' +
    'box-shadow:0 4px 24px rgba(0,0,0,.08);overflow:hidden">' +

    '<div style="background:linear-gradient(135deg,#0f0c29,#302b63,#24243e);padding:32px 36px;text-align:center">' +
    '<div style="font-size:32px;margin-bottom:10px">🧠</div>' +
    '<h1 style="color:#fff;margin:0;font-size:22px;letter-spacing:-.5px">Daily Interview Digest</h1>' +
    '<p style="color:rgba(255,255,255,.6);margin:8px 0 0;font-size:13px;font-family:monospace">' +
    dateStr + ' &nbsp;·&nbsp; 40 Questions (35 concept + 5 coding)</p></div>' +

    '<div style="padding:32px 36px">' +
    '<p style="color:#555;font-size:13px;margin:0 0 28px;padding:12px 16px;' +
    'background:#fffbeb;border-left:3px solid #f59e0b;border-radius:4px">' +
    '💡 <strong>How to use:</strong> Answer every concept question in your head first. ' +
    'For coding problems — write actual code before checking solutions. Struggle is the signal.</p>' +

    conceptSection("Premium AI / Data Science", "#6366f1", "🤖", aiQs) +
    conceptSection("Full Stack Engineering",    "#059669", "⚙️",  fsQs) +
    conceptSection("DSA Mastery — Concepts",    "#dc2626", "🔢",  dsaQs) +
    codingSection(codingRaw) +
    '</div>' +

    '<div style="background:#f8fafc;border-top:1px solid #e5e7eb;padding:20px 36px;text-align:center">' +
    '<p style="color:#9ca3af;font-size:12px;margin:0">' +
    '🚀 40 questions/day · rotating through 54 AI + 53 Fullstack + 25 DSA + 42 coding patterns · Stay sharp.</p>' +
    '</div></div></body></html>';
}


function sendQuestions() {
  try {
    var props = PropertiesService.getScriptProperties();
    var email = props.getProperty("RECIPIENT_EMAIL");
    if (!email) throw new Error("RECIPIENT_EMAIL not set in Script Properties.");

    var topics = selectTopicsForToday_();
    Logger.log("Seed: " + getTodaySeed_());

    var aiQs      = generateConceptQuestions_(topics.ai,  "AI/Data Science",       15);
    var fsQs      = generateConceptQuestions_(topics.fs,  "Full Stack Engineering", 15);
    var dsaQs     = generateConceptQuestions_(topics.dsa, "DSA Mastery",             5);
    var codingRaw = generateCodingProblems_(topics.dsaCoding);

    var ist     = new Date(new Date().toLocaleString("en-US", { timeZone: "Asia/Kolkata" }));
    var dateStr = ist.toLocaleDateString("en-IN", {
      weekday: "long", day: "numeric", month: "long", year: "numeric", timeZone: "Asia/Kolkata"
    });

    var html = buildQuestionEmail_(aiQs, fsQs, dsaQs, codingRaw, dateStr);

    // ✅ FIX: Save digest to Drive
    var subject = "🧠 Daily Digest — " + dateStr + " | 40 Interview Questions";
    createDigestAndAnswerFiles(subject, html);

    GmailApp.sendEmail(
      email,
      subject,
      "",
      { htmlBody: html }
    );
    Logger.log("✅ Digest sent to " + email);

  } catch (e) {
    Logger.log("❌ Error: " + e.message);
    try {
      var em = PropertiesService.getScriptProperties().getProperty("RECIPIENT_EMAIL");
      if (em) GmailApp.sendEmail(em, "⚠️ Daily Digest Error", e.message + "\n\nStack:\n" + e.stack);
    } catch (_) {}
    throw e;
  }
}


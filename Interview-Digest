function generateConceptQuestions_(topics, sectionName, count) {
  var topicList = topics.map(function(t) { return "- [" + t[0] + "] " + t[1]; }).join("\n");
  var prompt =
    "Generate exactly " + count + " deep interview questions covering these topics.\n" +
    "Rotate across ALL topics. Each question must require deep understanding — not recall.\n\n" +
    "Topics:\n" + topicList + "\n\nGenerate " + count + " questions:";

  var raw   = callClaude_(CONCEPT_SYSTEM, prompt);
  var lines = raw.split("\n").map(function(l) { return l.trim(); }).filter(function(l) { return l.length > 0; });
  var out   = [];
  lines.forEach(function(line) {
    var q = line.replace(/^\d+[\.\)]\s*/, "").trim();
    if (q.length > 20) out.push(q);
  });
  return out.slice(0, count);
}


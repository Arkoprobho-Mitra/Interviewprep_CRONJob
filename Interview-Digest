// ONE-TIME SETUP — Run ONCE to install the daily 6AM trigger
// ═══════════════════════════════════════════════════════════════

function setupTriggers() {
  ScriptApp.getProjectTriggers().forEach(function(t) {
    if (t.getHandlerFunction() === "sendQuestions") ScriptApp.deleteTrigger(t);
  });

  ScriptApp.newTrigger("sendQuestions")
    .timeBased()
    .atHour(6)
    .nearMinute(0)
    .inTimezone("Asia/Kolkata")
    .everyDays(1)
    .create();

  // ✅ FIX: Verify only one trigger was created
  var count = ScriptApp.getProjectTriggers().filter(function(t) {
    return t.getHandlerFunction() === "sendQuestions";
  }).length;

  Logger.log("✅ Trigger set: sendQuestions → 6:00 AM IST daily");
  Logger.log("⚠️ Active sendQuestions triggers: " + count + (count > 1 ? " — WARNING: duplicates detected! Run setupTriggers() again to clean up." : " — OK"));
  Logger.log("Run testDigest() to fire it right now and verify.");
}
